  "AutoCancel": {
    "CheckIntervalSeconds": 30,
    "EscalationMinutes": 1,
    "HardCancelMinutes": 3
  },
  "Msg91WhatsApp": {
    "AuthKey": "<set-via-env>",
    "IntegratedNumber": "919920920600",
    "TemplateName": "rally_login_verify",
    "TemplateNamespace": "<from-msg91-dashboard>",
    "TemplateLanguage": "en",
    "OtpExpiryMinutes": 5,
    "BaseUrl": "https://api.msg91.com/api/v5/whatsapp/whatsapp-outbound-message/bulk/"
  },
  "R2": {
    "AccountId": "<set-via-env>",
    "AccessKeyId": "<set-via-env>",
    "SecretAccessKey": "<set-via-env>",
    "BucketName": "rally-media",
    "PublicUrlBase": "https://pub-30cdda0e88e64114a0d72ca1bf1b80a5.r2.dev"
  },
  "PayU": {
    "MerchantKey": "<set-via-env>",
    "MerchantSalt": "<set-via-env>",
    "BaseUrl": "https://test.payu.in",
    "SuccessUrl": "https://localhost:5001/api/payments/return/success",
    "FailureUrl": "https://localhost:5001/api/payments/return/failure"
  }




