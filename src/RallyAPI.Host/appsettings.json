{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "Error",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithEnvironmentName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "<set-via-env>",
    "Redis": "<set-via-env>"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!!",
    "Issuer": "RallyAPI",
    "Audience": "RallyApp",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30,
    "PrivateKeyPath": "Keys/private.pem",
    "PublicKeyPath": "Keys/public.pem"
  },
  "ProRouting": {
    "BaseUrl": "https://preprod.logistics-buyer.prorouting.in",
    "ApiKey": "<set-via-env>",
    "TimeoutSeconds": 30,
    "DefaultOrderCategory": "F&B",
    "DefaultSearchCategory": "Immediate Delivery",
    "DefaultOrderWeight": 2,
    "RetryCount": 3,
    "Enabled": true
  },

  "MapMyIndia": {
    "ApiKey": "your-api-key",
    "BaseUrl": "https://apis.mapmyindia.com/advancedmaps/v1"
  },

  "GoogleMaps": {
    "ApiKey": "<set-via-env>",
    "BaseUrl": "https://maps.googleapis.com/maps/api",
    "TimeoutSeconds": 10,
    "Enabled": true,
    "TravelMode": "driving",
    "Region": "in"
  },
  "Delivery": {
    "OwnFleet": {
      "SearchRadiusKm": 5,
      "AcceptanceTimeoutSeconds": 30,
      "MaxRidersToTry": 10,
      "LocationMaxAgeMinutes": 5
    },
    "Pricing": {
      "BaseFee": 30,
      "BaseDistanceKm": 3,
      "PerKmRate": 10,
      "QuoteValidityMinutes": 15
    },
    "Quote": {
      "ValidityMinutes": 30,
      "ThirdPartyValidityMinutes": 5
    },
    "Dispatch": {
      "SearchRadiusKm": 5.0,
      "MaxRidersToTry": 10,
      "AcceptanceTimeoutSeconds": 30,
      "RiderEarningsPercentage": 80,
      "WebhookUrl": "https://your-domain.com/api/webhooks/prorouting"
    },
    "PrepTime": {
      "BaseMinutes": 15,
      "MinutesPerAdditionalItem": 5,
      "DispatchBufferMinutes": 5
    }
  },

